---
import bg from '../assets/images/hero/pages.jpg'
import Footer from '../components/footer.astro';
import Navlight from "../components/navbar/navlight.astro";
import { portfolioData } from '../data/data';
import Layout from "../layouts/Layout.astro";
---

<Layout>
    <Navlight/>

    <section class="bg-half-170 d-table w-100" style={`background: url('${bg.src}') center`}>
        <div class="bg-overlay bg-gradient-overlay"></div>
        <div class="container">
            <div class="row mt-5 justify-content-center">
                <div class="col-12">
                    <div class="title-heading text-center">
                        <h5 class="heading fw-semibold mb-0 sub-heading text-white title-dark">Portfolio</h5>
                    </div>
                </div>
            </div>

            <div class="position-middle-bottom">
                <nav aria-label="breadcrumb" class="d-block">
                    <ul class="breadcrumb breadcrumb-muted mb-0 p-0">
                        <li class="breadcrumb-item"><a href="/">Coral</a></li>
                        <li class="breadcrumb-item"><a href="javascript:void()">Portfolio</a></li>
                        <li class="breadcrumb-item"><a href="javascript:void()">Classic</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Two Columns</li>
                    </ul>
                </nav>
            </div>
        </div>
    </section>

    <div class="position-relative">
        <div class="shape overflow-hidden text-white">
            <svg viewBox="0 0 2880 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M0 48H1437.5H2880V0H2160C1442.5 52 720 0 720 0H0V48Z" fill="currentColor"></path>
            </svg>
        </div>
    </div>

    <section class="section">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-8">
                    <div class="row g-4">
                        {portfolioData.map((item)=>( 
                            <div class="col-md-6">
                                <div class="portfolio">
                                    <a href={item.image.src} class="lightbox"><img src={item.image.src} class="img-fluid rounded shadow" alt=""/></a>
        
                                    <div class="content mt-3">
                                        <a href="" class="text-dark fs-5 fw-medium link-title">{item.title}</a>
                                        <p class="text-muted mb-0">{item.desc}</p>
                                    </div>
                                </div>
                            </div>
                        ))}
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-12 mt-4">
                    <ul class="pagination justify-content-center mb-0">
                        <li class="page-item">
                            <a class="page-link" href="#" aria-label="Previous">
                                <span aria-hidden="true"><i class="mdi mdi-chevron-left align-middle fs-6"></i></span>
                            </a>
                        </li>
                        <li class="page-item"><a class="page-link" href="#">1</a></li>
                        <li class="page-item active"><a class="page-link" href="#">2</a></li>
                        <li class="page-item"><a class="page-link" href="#">3</a></li>
                        <li class="page-item">
                            <a class="page-link" href="#" aria-label="Next">
                                <span aria-hidden="true"><i class="mdi mdi-chevron-right align-middle fs-6"></i></span>
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <Footer/>

</Layout>