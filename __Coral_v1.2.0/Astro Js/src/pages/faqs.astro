---
import bg from '../assets/images/hero/pages.jpg'
import FaqFour from '../components/faq/faq-four.astro';
import FaqOne from '../components/faq/faq-one.astro';
import FaqThree from '../components/faq/faq-three.astro';
import FaqTwo from '../components/faq/faq-two.astro';
import Footer from '../components/footer.astro';
import Navlight from "../components/navbar/navlight.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout>
    <Navlight/>

    <section class="bg-half-170 d-table w-100" style={`background: url('${bg.src}') center`}>
        <div class="bg-overlay bg-gradient-overlay"></div>
        <div class="container">
            <div class="row mt-5 justify-content-center">
                <div class="col-12">
                    <div class="title-heading text-center">
                        <h5 class="heading fw-semibold mb-0 sub-heading text-white title-dark">FAQs</h5>
                    </div>
                </div>
            </div>

            <div class="position-middle-bottom">
                <nav aria-label="breadcrumb" class="d-block">
                    <ul class="breadcrumb breadcrumb-muted mb-0 p-0">
                        <li class="breadcrumb-item"><a href="/">Coral</a></li>
                        <li class="breadcrumb-item active" aria-current="page">FAQs</li>
                    </ul>
                </nav>
            </div>
        </div>
    </section>
    <div class="position-relative">
        <div class="shape overflow-hidden text-white">
            <svg viewBox="0 0 2880 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M0 48H1437.5H2880V0H2160C1442.5 52 720 0 720 0H0V48Z" fill="currentColor"></path>
            </svg>
        </div>
    </div>

    <section class="section">
            <div class="container">
                <div class="row justify-content-center">
                    <div class="col-lg-8 col-md-7 col-12">
                        <div class="section-title" id="tech">
                            <h4>Buying Product</h4>
                        </div>

                        <FaqOne/>

                        <div class="section-title mt-5" id="general">
                            <h4>General Questions</h4>
                        </div>

                       <FaqTwo/>

                        <div class="section-title mt-5" id="payment">
                            <h4>Payments Questions</h4>
                        </div>

                       <FaqThree/>

                        <div class="section-title mt-5" id="support">
                            <h4>Support Questions</h4>
                        </div>

                        <FaqFour/>
                    </div>
                </div>
            </div>
        </section>

    <Footer/>

</Layout>